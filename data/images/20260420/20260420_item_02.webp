0 0 0 0-.66 7.5 7.5 0 0 0-13.888 0 1 1 0 0 0 0 .66 7.5 7.5 0 0 0 13.888 0"></path></svg></div><p class="mt-4 text-sm font-medium text-gray-500 uppercase tracking-widest opacity-0 group-hover/card:opacity-100 transform translate-y-2 group-hover/card:translate-y-0 transition-all duration-500 font-geist absolute bottom-8 z-20">Visual Fidelity</p></div><div class="p-8 rounded-[32px] bg-[#151515] border border-white/5 hover:border-white/10 transition-all duration-500 flex flex-col justify-between min-h-[220px] group/card hover:-translate-y-1 shadow-2xl relative overflow-hidden"><div class="absolute top-0 right-0 p-6 opacity-20 transition-all duration-500 group-hover/card:opacity-50"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-layout-template w-10 h-10 text-white" aria-hidden="true"><rect width="18" height="7" x="3" y="3" rx="1"></rect><rect width="9" height="7" x="3" y="14" rx="1"></rect><rect width="5" height="7" x="16" y="14" rx="1"></rect></svg></div><p class="text-lg text-gray-300 font-light leading-relaxed tracking-tight font-geist">&quot;Static layouts turn into functional, responsive websites. I translate designs exactly into code.&quot;</p><div class="flex items-center gap-3 mt-6 pt-6 border-t border-white/5"><div><div class="text-sm font-semibold text-white font-geist">Pixel-Perfect</div><div class="text-xs text-gray-500 font-geist">Implementation</div></div></div></div><div class="flex flex-col min-h-[220px] hover:opacity-100 transition-all duration-500 group/card overflow-hidden bg-[#121212] opacity-60 border-white/5 border rounded-[32px] relative items-center justify-center"><div class="absolute inset-0 bg-[url(https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/assets/assets/c9c4d84b-1b17-41c3-86c7-db3ffe513f31_1600w.webp)] bg-cover bg-center scale-110"></div><div class="group-hover/card:o